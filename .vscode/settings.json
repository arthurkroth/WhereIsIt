{
  "// comment": "Project-level VS Code settings - suppresses false errors in node_modules",
  "typescript.preferences.excludeDeprecated": true,
  "typescript.disableAutomaticTypeAcquisition": false,
  "search.exclude": {
    "**/node_modules": true
  },
  "files.watcherExclude": {
    "**/node_modules/**": true
  },
  "typescript.validate.enable": true,
  "js/ts.implicitProjectConfig.checkJs": false
}